{
	"name": "translator",
	"version": "1.0.0",
	"description": "Tool to translate json content via API",
	"main": "index.ts",
	"scripts": {
		"start": "tsx src/index.ts",
		"libre": "pipenv run libretranslate --load-only en,fr,zt,ms --host 127.0.0.1 --port 5000",
		"example": "tsx src/index.ts -log --input=./example/article/en-US/ --output=./example/article/",
		"benchmark": "tsx src/index.ts -log -skip-cache -verbose -override --input=./example/benchmark/16384/en-US/ --output=./example/benchmark/16384/",
		"batch": "tsx src/index.ts -log -dry-run -verbose -skip-cache -override --target-locale=zh-TW --input=./example/batch/en-US/ --output=./example/batch/"
	},
	"author": "Nassim El Khantour",
	"license": "ISC",
	"devDependencies": {
		"@types/node": "^25.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@google-cloud/translate": "^9.3.0",
		"deepl-node": "^1.24.0",
		"dotenv": "^17.3.1"
	}
}
