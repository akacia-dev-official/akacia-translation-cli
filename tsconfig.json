{
	"compilerOptions": {
		"target": "es2020",
		"lib": [
			"DOM",
			"es2021"
		],
		"strict": true,
		"outDir": "dist",
		"allowJs": true,
		"jsx": "react-jsx",
		"moduleResolution": "node",
		"allowSyntheticDefaultImports": true,
		"typeRoots": [
			"./node_modules/@types"
		],
		"baseUrl": "./",
		"include": [
			"**/*.tsx",
			"**/*.ts",
		]
	}
